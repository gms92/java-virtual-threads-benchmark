{
  "title": "Java Performance Comparison",
  "uid": "java-perf",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Request Latency p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, java_version) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "Java {{java_version}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Latency p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, java_version) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "Java {{java_version}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 3,
      "title": "Throughput (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (java_version) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "Java {{java_version}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 4,
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Java {{java_version}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 5,
      "title": "Heap Memory",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "Java {{java_version}} - {{id}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "Java {{java_version}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {}
}
